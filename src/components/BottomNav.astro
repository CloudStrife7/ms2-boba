---
interface Props {
  activePage?: 'home' | 'tour' | 'armory' | 'about';
}
const { activePage } = Astro.props;
---

<nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#131411] py-3 px-6 flex justify-around items-center z-50 border-t border-[#1b1c19]">
  <a href="/index.html">
    <span
      class="material-symbols-outlined"
      class:list={[activePage === 'home' ? 'text-[#F59E01]' : 'text-[#b7cda9]/60']}
      style={activePage === 'home' ? "font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24" : ''}
    >terminal</span>
  </a>
  <a href="/about.html">
    <span
      class="material-symbols-outlined"
      class:list={[activePage === 'about' ? 'text-[#F59E01]' : 'text-[#b7cda9]/60']}
      style={activePage === 'about' ? "font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24" : ''}
    >person</span>
  </a>
  <a href="/tour.html">
    <span
      class="material-symbols-outlined"
      class:list={[activePage === 'tour' ? 'text-[#F59E01]' : 'text-[#b7cda9]/60']}
      style={activePage === 'tour' ? "font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24" : ''}
    >radar</span>
  </a>
  <a href="/armory.html">
    <span
      class="material-symbols-outlined"
      class:list={[activePage === 'armory' ? 'text-[#F59E01]' : 'text-[#b7cda9]/60']}
      style={activePage === 'armory' ? "font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24" : ''}
    >inventory_2</span>
  </a>
</nav>
