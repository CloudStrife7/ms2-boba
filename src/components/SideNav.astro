---
interface Props {
  activePage?: 'home' | 'tour' | 'armory' | 'about';
}
const { activePage } = Astro.props;

const links = [
  { href: '/index.html', label: 'Home', icon: 'terminal', id: 'home' },
  { href: '/about.html', label: 'About', icon: 'person', id: 'about' },
  { href: '/tour.html', label: 'Tour of Duty', icon: 'radar', id: 'tour' },
  { href: '/armory.html', label: 'Armory', icon: 'inventory_2', id: 'armory' },
];
---

<aside class="hidden md:flex flex-col h-full w-64 fixed left-0 top-0 bg-[#1b1c19] border-r border-[#444840]/15 shadow-[24px_0_40px_rgba(228,226,222,0.06)] py-8 z-20">
  <div class="px-6 mb-10">
    <div class="text-lg font-bold text-[#F59E01] font-headline uppercase tracking-widest">MS2 BOBA</div>
    <div class="text-[10px] text-[#b7cda9]/50 font-medium uppercase tracking-widest">BH-7024</div>
  </div>

  <nav class="flex flex-col flex-1 font-headline text-sm font-medium uppercase tracking-widest">
    {links.map((link) => (
      <a
        href={link.href}
        class={
          activePage === link.id
            ? 'bg-[#4C6043] text-[#e4e2de] border-l-4 border-[#F59E01] px-6 py-3 flex items-center gap-4 transition-all'
            : 'text-[#b7cda9]/50 px-6 py-3 hover:bg-[#1f201d] hover:text-[#F59E01] transition-all duration-300 flex items-center gap-4'
        }
      >
        <span class="material-symbols-outlined">{link.icon}</span>
        <span>{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="px-6 mt-auto space-y-4">
    <a
      href="https://thebhg.net/forum/index.php?/topic/8520-bobarearmored-bh-7024/"
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full py-3 bg-[#4C6043] text-[#e4e2de] font-bold text-[10px] uppercase tracking-widest text-center hover:brightness-110 transition-all"
    >
      BHG Forum Thread
    </a>
    <div class="flex flex-col gap-2 font-headline text-[10px] uppercase tracking-widest">
      <a class="text-[#b7cda9]/40 hover:text-[#6D0827] flex items-center gap-2 px-2 py-1" href="https://www.501st.com/" target="_blank" rel="noopener noreferrer">
        <span class="material-symbols-outlined text-sm">shield</span>501st Legion
      </a>
      <a class="text-[#b7cda9]/40 hover:text-[#6D0827] flex items-center gap-2 px-2 py-1" href="https://www.wigarrison.com/" target="_blank" rel="noopener noreferrer">
        <span class="material-symbols-outlined text-sm">groups</span>WI Garrison
      </a>
    </div>
  </div>
</aside>
