---
interface Props {
  activePage?: 'home' | 'tour' | 'armory' | 'about';
}
const { activePage } = Astro.props;

const links = [
  { href: '/index.html', label: 'Home', id: 'home' },
  { href: '/about.html', label: 'About', id: 'about' },
  { href: '/tour.html', label: 'Tour of Duty', id: 'tour' },
  { href: '/armory.html', label: 'Armory', id: 'armory' },
];
---

<header class="bg-[#131411] top-0 z-50 sticky">
  <div class="flex justify-between items-center w-full px-6 h-16 max-w-none">
    <div class="text-xl font-black text-[#b7cda9] tracking-widest font-headline uppercase">
      MS2 BOBA
    </div>
    <nav class="hidden md:flex items-center gap-8 font-headline tracking-tighter uppercase font-bold text-sm">
      {links.map((link) => (
        <a
          href={link.href}
          class={
            activePage === link.id
              ? 'text-[#F59E01] border-b-2 border-[#F59E01] pb-1'
              : 'text-[#b7cda9]/60 hover:text-[#b7cda9] transition-colors'
          }
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-4">
      <button class="hover:bg-[#4C6043]/20 transition-colors p-2 rounded-sm scale-95 active:opacity-80">
        <span class="material-symbols-outlined text-[#b7cda9]">notifications</span>
      </button>
      <button class="hover:bg-[#4C6043]/20 transition-colors p-2 rounded-sm scale-95 active:opacity-80">
        <span class="material-symbols-outlined text-[#b7cda9]">settings</span>
      </button>
    </div>
  </div>
  <div class="bg-[#1b1c19] h-[1px] w-full"></div>
</header>
