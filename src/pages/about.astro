---
import Layout from '../layouts/Layout.astro';
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import siteData from '../data/site.json';

const { troopCount, yearsActive } = siteData;
---

<Layout title="About | MS2 Boba">
  <body class="flex min-h-screen bg-[#131411] text-[#e4e2de] font-body">

    <SideNav activePage="about" />

    <div class="flex-1 flex flex-col md:ml-64">
      <TopBar activePage="about" />

      <!-- Main Content -->
      <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12 md:py-20">

        <!-- Hero Section -->
        <section class="relative h-[340px] md:h-[420px] mb-20 rounded-sm overflow-hidden">
          <div class="absolute inset-0">
            <img
              alt="Boba Fett at C2E2 Chicago Comic &amp; Entertainment Expo"
              class="w-full h-full object-cover"
              src="/c2e2-hero.jpg"
              style="object-position: 60% 12%;"
              fetchpriority="high"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[#131411] via-[#131411]/80 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-[#131411] via-transparent to-transparent"></div>
          </div>
          <div class="relative h-full flex flex-col justify-end p-8 md:p-12">
            <span class="font-label text-xs tracking-[0.3em] text-[#4C6043] uppercase mb-4 block">Personnel File</span>
            <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter uppercase leading-none">
              About <span class="text-[#8e9288]">Me</span>
            </h1>
            <div class="mt-4 bg-[#131411]/80 backdrop-blur-sm p-4 rounded-sm border-l-2 border-[#F59E01] w-fit">
              <div class="font-label text-[10px] text-[#8e9288] uppercase tracking-widest mb-1">Designation</div>
              <div class="font-headline font-bold text-xl text-[#e4e2de]">BH-7024</div>
            </div>
          </div>
        </section>

        <!-- Profile Section -->
        <section class="mb-24">
          <div class="flex flex-col lg:flex-row gap-12">

            <!-- Profile Card -->
            <div class="lg:w-1/3">
              <div class="bg-[#1b1c19] rounded-sm overflow-hidden border border-[#434840]/20">
                <div class="aspect-square bg-[#131411] relative overflow-hidden">
                  <img
                    alt="Boba Fett Costume"
                    class="w-full h-full object-cover opacity-80"
                    style="object-position: left center;"
                    src="/images/about-profile.jpg"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#1b1c19] to-transparent"></div>
                </div>
                <div class="p-6 space-y-4">
                  <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-[#F59E01]" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24">verified</span>
                    <span class="font-label text-[10px] uppercase tracking-[0.2em] text-[#F59E01] font-bold">501st Approved Member</span>
                  </div>
                  <div class="space-y-3">
                    <div class="flex justify-between text-xs border-b border-[#434840]/30 pb-2">
                      <span class="text-[#8e9288] uppercase font-label tracking-widest">ID#</span>
                      <span class="text-[#e4e2de] font-bold">BH-7024</span>
                    </div>
                    <div class="flex justify-between text-xs border-b border-[#434840]/30 pb-2">
                      <span class="text-[#8e9288] uppercase font-label tracking-widest">Legion</span>
                      <span class="text-[#e4e2de] font-bold">501st</span>
                    </div>
                    <div class="flex justify-between text-xs border-b border-[#434840]/30 pb-2">
                      <span class="text-[#8e9288] uppercase font-label tracking-widest">Detachment</span>
                      <span class="text-[#e4e2de] font-bold">Bounty Hunters Guild</span>
                    </div>
                    <div class="flex justify-between text-xs border-b border-[#434840]/30 pb-2">
                      <span class="text-[#8e9288] uppercase font-label tracking-widest">Garrison</span>
                      <span class="text-[#e4e2de] font-bold">Wisconsin</span>
                    </div>
                    <div class="flex justify-between text-xs">
                      <span class="text-[#8e9288] uppercase font-label tracking-widest">Costume</span>
                      <span class="text-[#e4e2de] font-bold">Boba Fett (RE-ARMORED)</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Bio Content -->
            <div class="lg:w-2/3 space-y-12">
              <div class="relative pl-8 border-l-2 border-[#6D0827]">
                <h3 class="font-headline text-2xl font-bold mb-4 uppercase tracking-wider">Background</h3>
                <p class="font-body text-[#b7cda9] leading-relaxed mb-4">
                  A proud member of the 501st Legion and the Bounty Hunters Guild, trooping as Boba Fett in his Re-Armored configuration from The Book of Boba Fett. Based in Wisconsin, operating across the Wisconsin Garrison's territory.
                </p>
                <p class="font-body text-[#b7cda9] leading-relaxed">
                  What started as a passion for Star Wars and prop-building evolved into a full commitment to the 501st Legion's mission of bringing joy through costuming while giving back to the community. Every troop is an opportunity to make someone's day and represent the galaxy's most feared bounty hunter.
                </p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-[#1b1c19] p-6 rounded-sm border-t border-[#4C6043]">
                  <span class="material-symbols-outlined text-3xl text-[#4C6043] mb-4 block">military_tech</span>
                  <h4 class="font-headline text-lg font-bold uppercase mb-2">501st Legion</h4>
                  <p class="text-sm text-[#b7cda9] leading-relaxed">The world's premier Star Wars costuming organization. Vader's Fist. Bad guys doing good.</p>
                </div>
                <div class="bg-[#1b1c19] p-6 rounded-sm border-t border-[#6D0827]">
                  <span class="material-symbols-outlined text-3xl text-[#6D0827] mb-4 block">shield</span>
                  <h4 class="font-headline text-lg font-bold uppercase mb-2">Squad Leader</h4>
                  <p class="text-sm text-[#b7cda9] leading-relaxed">Leading Devastator Squad within the Wisconsin Garrison. Coordinating deployments and keeping the squad mission-ready.</p>
                </div>
                <div class="bg-[#1b1c19] p-6 rounded-sm border-t border-[#F59E01]">
                  <span class="material-symbols-outlined text-3xl text-[#F59E01] mb-4 block">gavel</span>
                  <h4 class="font-headline text-lg font-bold uppercase mb-2">Bounty Hunters Guild</h4>
                  <p class="text-sm text-[#b7cda9] leading-relaxed">The 501st detachment dedicated to the galaxy's hunters, mercenaries, and those who work for the highest bidder.</p>
                </div>
              </div>

              <!-- Stats Grid -->
              <div class="grid grid-cols-3 gap-1 bg-[#131411] border border-[#434840]/20 overflow-hidden rounded-sm">
                <div class="bg-[#1b1c19] p-6 text-center">
                  <div class="font-headline text-3xl font-extrabold text-[#F59E01]">{troopCount}</div>
                  <div class="font-label text-[10px] text-[#8e9288] uppercase tracking-widest mt-1">Troops Completed</div>
                </div>
                <div class="bg-[#1b1c19] p-6 text-center">
                  <div class="font-headline text-3xl font-extrabold text-[#4C6043]">{yearsActive}</div>
                  <div class="font-label text-[10px] text-[#8e9288] uppercase tracking-widest mt-1">Years of Service</div>
                </div>
                <div class="bg-[#1b1c19] p-6 text-center">
                  <div class="font-headline text-3xl font-extrabold text-[#6D0827]">WI</div>
                  <div class="font-label text-[10px] text-[#8e9288] uppercase tracking-widest mt-1">Home Sector</div>
                </div>
              </div>

              <!-- External Links -->
              <div class="flex flex-wrap gap-4">
                <a href="https://thebhg.net/forum/index.php?/topic/8520-bobarearmored-bh-7024/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 bg-[#4C6043] text-[#e4e2de] font-headline font-bold text-sm rounded-sm hover:brightness-110 transition-all">
                  BHG Forum Thread
                  <span class="material-symbols-outlined text-sm">open_in_new</span>
                </a>
                <a href="/tour.html" class="inline-flex items-center gap-2 px-6 py-3 border border-[#434840]/50 text-[#e4e2de] font-headline font-bold text-sm rounded-sm hover:border-[#F59E01] hover:text-[#F59E01] transition-all">
                  View Tour of Duty
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
              </div>
            </div>
          </div>
        </section>
      </main>

      <Footer />
    </div>

    <!-- BottomNavBar (Mobile Only) -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#131411] py-3 px-6 flex justify-around items-center z-50 border-t border-[#1b1c19]">
      <a href="/index.html"><span class="material-symbols-outlined text-[#b7cda9]/60">terminal</span></a>
      <a href="/about.html"><span class="material-symbols-outlined text-[#F59E01]" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24">person</span></a>
      <a href="/tour.html"><span class="material-symbols-outlined text-[#b7cda9]/60">radar</span></a>
      <a href="/armory.html"><span class="material-symbols-outlined text-[#b7cda9]/60">inventory_2</span></a>
    </nav>

  </body>
</Layout>
