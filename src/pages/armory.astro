---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';

const kitComponents = [
  { name: 'Helmet', detail: 'Moss green dome with burgundy mandibles, T-visor, rangefinder, orange kill-stripes. RedBowProps V3.' },
  { name: 'Chest Armor', detail: 'Dark green multi-plate with red slots and Jaster Mereel\'s sigil. BobaMAker kit.' },
  { name: 'Gauntlets', detail: 'Burgundy shells with calculator keypad and whipcord housing.' },
  { name: 'Shoulder Armor', detail: 'Golden orange pauldrons with Mythosaur skull detail.' },
  { name: 'Knee Armor', detail: 'Golden orange with dart launcher pads.' },
  { name: 'Jet Pack', detail: 'Dark satin green Z-6 with beacon assembly.' },
  { name: 'Flak Jacket', detail: 'Black cotton with shoulder tabs.' },
  { name: 'Belt and Holster', detail: 'Leather ammo belt with western-style blaster holster.' },
  { name: 'Gloves', detail: 'Two-tone leather with riveted hand plates.' },
  { name: 'Boots and Gaiters', detail: 'Black distressed leather with metal toe caps.' },
  { name: 'Girth Belt', detail: 'Braided polypropylene rope belt.' },
  { name: 'Hakama Pants', detail: 'Black raw silk with screen-accurate weathering.' },
] as const;

const buildTimeline = [
  { phase: 'Decision', date: 'January 2025', detail: 'Selected Re-Armored Boba Fett as focus costume after watching The Book of Boba Fett.' },
  { phase: 'Parts Arrival', date: 'February 2025', detail: 'BobaMAker armor kit and RedBowProps V3 helmet delivered. EE-3 prop sourced.' },
  { phase: 'Painting', date: 'March 2025', detail: 'Montana Black paints — moss green, burgundy, golden orange applied and weathered over multiple sessions.' },
  { phase: 'Assembly', date: 'April 2025', detail: 'Full kit assembled, strapping fitted and adjusted, electronics tested.' },
  { phase: 'Deployment Test', date: 'May 2025', detail: 'First trial wear at local event. Comfort adjustments made to strapping.' },
  { phase: '501st / BHG Approval', date: 'May 2025', detail: 'Submitted to 501st Legion and Bounty Hunters Guild review — approved.' },
] as const;
---

<Layout title="The Armory" description="Complete kit breakdown for BH-7024 — Boba Fett Re-Armored build log and loadout.">
  <div class="flex flex-col min-h-screen bg-background">
    <TopBar activePage="armory" />

    <main class="flex-grow max-w-5xl mx-auto w-full px-6 pt-24 pb-24 md:pb-12 space-y-12">

      <!-- Page header -->
      <section class="flex items-start justify-between flex-wrap gap-4 pb-4 border-b border-outline-variant/30">
        <div>
          <span class="font-label text-[10px] tracking-[0.3em] text-melon uppercase block mb-2">Protocol Designation: BH-7024</span>
          <h1 class="font-headline text-5xl md:text-6xl font-extrabold tracking-tighter leading-none uppercase">
            The Armory.
          </h1>
          <p class="font-body text-on-surface-variant mt-3 max-w-xl leading-relaxed">
            A definitive archive of high-fidelity tactical gear. Built for the Outer Rim. Maintained with industrial precision.
          </p>
        </div>
        <div class="bg-surface-container-high p-4 border-l-4 border-storm shrink-0">
          <span class="font-label text-[10px] text-storm uppercase tracking-widest block mb-2">System Status</span>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-storm animate-pulse"></div>
            <span class="font-label text-xs uppercase text-on-surface font-bold">Armor Integrity: 98.4%</span>
          </div>
        </div>
      </section>

      <!-- Kit components grid -->
      <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-headline text-2xl font-bold uppercase tracking-tight">The Kit</h2>
          <div class="h-px flex-grow bg-outline-variant/40"></div>
          <span class="font-label text-[10px] text-outline uppercase tracking-widest">{kitComponents.length} Components</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-outline-variant/20">
          {kitComponents.map((item, i) => (
            <div class="bg-background hover:bg-surface-container-low transition-colors p-5 flex gap-4">
              <span class="font-headline font-black text-2xl text-melon shrink-0 w-8 text-right leading-none mt-0.5">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <p class="font-label font-bold text-sm text-on-surface uppercase tracking-wide">{item.name}</p>
                <p class="font-body text-xs text-on-surface-variant mt-1 leading-relaxed">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Build log timeline -->
      <section>
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-headline text-2xl font-bold uppercase tracking-tight">Build Log</h2>
          <div class="h-px flex-grow bg-outline-variant/40"></div>
          <span class="font-label text-[10px] text-outline uppercase tracking-widest">2025 Campaign</span>
        </div>
        <div class="relative border-l-2 border-cardinal/40 pl-8 space-y-px">
          {buildTimeline.map((entry) => (
            <div class="bg-surface-container-low hover:bg-surface-container transition-colors p-5 flex gap-6">
              <div class="shrink-0 w-28 text-right">
                <p class="font-label font-bold text-xs text-cardinal uppercase tracking-wider">{entry.phase}</p>
                <p class="font-label text-[11px] text-outline mt-0.5">{entry.date}</p>
              </div>
              <div class="w-px bg-outline-variant/60 shrink-0"></div>
              <p class="font-body text-sm text-on-surface-variant leading-relaxed">{entry.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Approval badges -->
      <section class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 bg-surface-container-low p-6 border-l-4 border-storm flex items-start gap-4">
          <span class="material-symbols-outlined text-storm text-2xl shrink-0" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24">verified</span>
          <div>
            <p class="font-label font-bold text-xs text-storm uppercase tracking-widest mb-1">501st Legion Approved</p>
            <p class="font-body text-sm text-on-surface-variant leading-relaxed">Reviewed and approved by the 501st Legion costume review board.</p>
          </div>
        </div>
        <div class="flex-1 bg-surface-container-low p-6 border-l-4 border-melon flex items-start gap-4">
          <span class="material-symbols-outlined text-melon text-2xl shrink-0" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24">military_tech</span>
          <div>
            <p class="font-label font-bold text-xs text-melon uppercase tracking-widest mb-1">BHG Certified Hunter</p>
            <p class="font-body text-sm text-on-surface-variant leading-relaxed">Full BHG membership with all armor meeting screen-accuracy standards.</p>
          </div>
        </div>
      </section>

    </main>

    <Footer />
  </div>

  <BottomNav activePage="armory" />
</Layout>
