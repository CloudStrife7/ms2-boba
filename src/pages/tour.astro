---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';
import siteData from '../data/site.json';

const { troopCount, nextDeployment, missions } = siteData;

const milestones = [
  { count: 10, label: 'White Pin', icon: 'workspace_premium' },
  { count: 25, label: 'Silver Pin', icon: 'workspace_premium' },
  { count: 50, label: 'Gold Pin', icon: 'workspace_premium' },
  { count: 75, label: 'Coin', icon: 'toll' },
] as const;

function formatCountdown(isoDate: string) {
  const target = new Date(isoDate);
  const now = new Date();
  const diff = target.getTime() - now.getTime();
  if (diff <= 0) return null;
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  return days;
}

const daysUntilNext = nextDeployment?.isoDate ? formatCountdown(nextDeployment.isoDate) : null;
const isUpcoming = daysUntilNext !== null && daysUntilNext >= 0;
---

<Layout title="Tour of Duty" description="Complete mission log — every troop event, every deployment for BH-7024.">
  <div class="flex flex-col min-h-screen bg-background">
      <TopBar activePage="tour" />

      <main class="flex-grow pt-20 pb-24 md:pb-12 px-6 md:px-12">
        <!-- Header -->
        <section class="mb-16">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
              <span class="font-label text-xs tracking-[0.3em] text-storm uppercase mb-4 block">Deployment Records</span>
              <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter uppercase leading-none">
                Tour <span class="text-outline">of</span> Duty
              </h1>
            </div>
            <div class="bg-surface-container-low p-4 border-l-2 border-melon">
              <div class="font-label text-[10px] text-outline uppercase tracking-widest mb-1">Status Report</div>
              <div class="font-headline font-bold text-xl text-on-surface">{troopCount} MISSIONS LOGGED</div>
            </div>
          </div>
        </section>

        <!-- Milestone Tracker HUD -->
        <section class="mb-16 bg-surface-container-low p-6 border border-outline-variant/20">
          <div class="font-label text-[10px] text-melon uppercase tracking-widest mb-6">Milestone Tracker</div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {milestones.map((m) => {
              const earned = troopCount >= m.count;
              const progress = Math.min(100, Math.round((troopCount / m.count) * 100));
              return (
                <div class={`p-4 border ${earned ? 'border-melon/40 bg-melon/5' : 'border-outline-variant/30'}`}>
                  <span class={`material-symbols-outlined text-2xl mb-2 block ${earned ? 'text-melon' : 'text-outline'}`}
                    style={earned ? "font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24" : ''}>
                    {m.icon}
                  </span>
                  <div class={`font-headline font-bold text-lg ${earned ? 'text-melon' : 'text-outline'}`}>{m.label}</div>
                  <div class="font-label text-[10px] text-outline uppercase tracking-widest mt-1">{m.count} Troops</div>
                  <div class="mt-3 h-1 bg-outline-variant/30 overflow-hidden">
                    <div class={`h-full transition-all ${earned ? 'bg-melon' : 'bg-storm/50'}`} style={`width: ${progress}%`}></div>
                  </div>
                  {!earned && (
                    <div class="font-label text-[9px] text-outline mt-1">{troopCount}/{m.count}</div>
                  )}
                  {earned && (
                    <div class="font-label text-[9px] text-melon mt-1 flex items-center gap-1">
                      <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1">check_circle</span>
                      Earned
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </section>

        <!-- Timeline -->
        <section class="relative">
          <!-- Vertical spine -->
          <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-[1px] bg-outline-variant md:-translate-x-1/2"></div>

          <div class="space-y-20 relative">

            <!-- Upcoming deployment -->
            {nextDeployment && (
              <div class="relative flex flex-col md:flex-row items-start md:items-center">
                <div class="md:w-1/2 md:pr-12 md:text-right mb-4 md:mb-0">
                  <div class="font-label text-xs text-cardinal tracking-widest font-bold mb-1 uppercase">
                    {isUpcoming ? 'Next Deployment' : 'Last Scheduled'}
                  </div>
                  <h3 class="font-headline text-2xl font-bold uppercase leading-tight">{nextDeployment.name}</h3>
                  <p class="font-body text-outline text-sm mt-1">{nextDeployment.location}</p>
                </div>
                <!-- Timeline dot -->
                <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-cardinal border-4 border-background transform -translate-x-1/2 z-10"></div>
                <div class="md:w-1/2 md:pl-12 pl-12">
                  <div class="font-label text-sm text-on-surface tracking-tighter uppercase">{nextDeployment.date}</div>
                  {nextDeployment.time && (
                    <div class="font-label text-xs text-outline mt-0.5">{nextDeployment.time}</div>
                  )}
                  {isUpcoming ? (
                    <div class="mt-2 inline-flex items-center gap-2 bg-cardinal/10 text-cardinal px-3 py-1 border border-cardinal/30">
                      <span class="w-1.5 h-1.5 rounded-full bg-cardinal animate-pulse"></span>
                      <span class="font-label text-[10px] uppercase font-bold tracking-widest">
                        {daysUntilNext === 0 ? 'Today!' : `${daysUntilNext} Days Out`}
                      </span>
                    </div>
                  ) : (
                    <div class="mt-2 inline-flex items-center gap-2 bg-outline-variant/20 text-outline px-3 py-1 border border-outline-variant/30">
                      <span class="font-label text-[10px] uppercase font-bold tracking-widest">Completed</span>
                    </div>
                  )}
                </div>
              </div>
            )}

            <!-- Mission entries -->
            {missions.map((mission, i) => {
              const isLeft = i % 2 === 0;
              return (
                <div class="relative flex flex-col md:flex-row items-start md:items-center hover:opacity-100 transition-all duration-500">
                  {isLeft ? (
                    <>
                      <div class="md:w-1/2 md:pr-12 md:text-right mb-4 md:mb-0">
                        <div class="font-label text-xs text-storm tracking-widest font-bold mb-1 uppercase">
                          Mission {String(mission.number).padStart(2, '0')}
                        </div>
                        <h3 class="font-headline text-2xl font-bold uppercase leading-tight">{mission.eventName}</h3>
                        <p class="font-body text-outline text-sm mt-1">{mission.location}</p>
                      </div>
                      <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-storm border-4 border-background transform -translate-x-1/2 z-10"></div>
                      <div class="md:w-1/2 md:pl-12 pl-12 space-y-3">
                        <div class="font-label text-sm text-on-surface tracking-tighter uppercase">{mission.date}</div>
                        {mission.photo && !mission.photo.includes('hero-bg') && (
                          <div class="w-full max-w-xs overflow-hidden">
                            <img
                              src={mission.photo.startsWith('http') ? mission.photo : `/${mission.photo}`}
                              alt={mission.eventName}
                              class="w-full h-32 object-cover opacity-80 hover:opacity-100 transition-opacity cursor-pointer"
                              onclick={`openSpotlight('${mission.photo.startsWith('http') ? mission.photo : '/' + mission.photo}')`}
                            />
                          </div>
                        )}
                        <div class="inline-flex items-center gap-2 bg-storm/10 text-storm px-3 py-1 border border-storm/30">
                          <span class="material-symbols-outlined text-[12px] text-storm" style="font-variation-settings: 'FILL' 1">check_circle</span>
                          <span class="font-label text-[10px] uppercase font-bold tracking-widest">Successful Mission</span>
                        </div>
                      </div>
                    </>
                  ) : (
                    <>
                      <div class="md:w-1/2 md:pr-12 pl-12 md:pl-0 space-y-3 order-2 md:order-1">
                        <div class="font-label text-sm text-on-surface tracking-tighter uppercase">{mission.date}</div>
                        {mission.photo && !mission.photo.includes('hero-bg') && (
                          <div class="w-full max-w-xs overflow-hidden">
                            <img
                              src={mission.photo.startsWith('http') ? mission.photo : `/${mission.photo}`}
                              alt={mission.eventName}
                              class="w-full h-32 object-cover opacity-80 hover:opacity-100 transition-opacity cursor-pointer"
                              onclick={`openSpotlight('${mission.photo.startsWith('http') ? mission.photo : '/' + mission.photo}')`}
                            />
                          </div>
                        )}
                        <div class="inline-flex items-center gap-2 bg-storm/10 text-storm px-3 py-1 border border-storm/30">
                          <span class="material-symbols-outlined text-[12px] text-storm" style="font-variation-settings: 'FILL' 1">check_circle</span>
                          <span class="font-label text-[10px] uppercase font-bold tracking-widest">Successful Mission</span>
                        </div>
                      </div>
                      <div class="absolute left-4 md:left-1/2 w-4 h-4 bg-storm border-4 border-background transform -translate-x-1/2 z-10"></div>
                      <div class="md:w-1/2 md:pl-12 mb-4 md:mb-0 order-1 md:order-2">
                        <div class="font-label text-xs text-storm tracking-widest font-bold mb-1 uppercase">
                          Mission {String(mission.number).padStart(2, '0')}
                        </div>
                        <h3 class="font-headline text-2xl font-bold uppercase leading-tight">{mission.eventName}</h3>
                        <p class="font-body text-outline text-sm mt-1">{mission.location}</p>
                      </div>
                    </>
                  )}
                </div>
              );
            })}

          </div>
        </section>

        <!-- Data Grid break -->
        <section class="mt-24">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-1 bg-background border border-outline-variant/20 overflow-hidden">
            <div class="p-8 bg-surface-container-low">
              <div class="font-label text-[10px] text-storm tracking-widest uppercase mb-4">Tactical Coverage</div>
              <div class="font-headline font-bold text-5xl text-melon">{troopCount}</div>
              <div class="font-label text-[10px] text-outline uppercase tracking-widest mt-1">Missions Complete</div>
              <p class="font-body text-xs text-outline mt-4 leading-relaxed">
                Every deployment contributes to the 501st's mission of charity and community engagement across Wisconsin and beyond.
              </p>
            </div>
            <div class="p-8 bg-surface-container-low">
              <div class="font-label text-[10px] text-melon tracking-widest uppercase mb-4">Critical Intel</div>
              <div class="font-headline font-bold text-3xl text-on-surface mb-2 tracking-tighter italic">"ALWAYS FIRST"</div>
              <p class="font-body text-xs text-outline leading-relaxed">
                The 501st Legion puts its best foot forward — whether it's a hospital visit or a convention floor. This is how BH-7024 operates.
              </p>
            </div>
            <div class="p-8 bg-surface-container-low flex flex-col justify-between">
              <div>
                <div class="font-label text-[10px] text-cardinal tracking-widest uppercase mb-4">Archive Links</div>
                <div class="space-y-3">
                  <a
                    href="https://thebhg.net/forum/index.php?/topic/8520-bobarearmored-bh-7024/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-between group cursor-pointer"
                  >
                    <span class="font-body text-sm text-on-surface group-hover:text-storm transition-colors">BHG Forum Thread</span>
                    <span class="material-symbols-outlined text-sm text-outline group-hover:translate-x-1 transition-transform">arrow_forward</span>
                  </a>
                  <div class="w-full h-[1px] bg-outline-variant/20"></div>
                  <a
                    href="https://www.501st.com/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-between group cursor-pointer"
                  >
                    <span class="font-body text-sm text-on-surface group-hover:text-storm transition-colors">501st Legion</span>
                    <span class="material-symbols-outlined text-sm text-outline group-hover:translate-x-1 transition-transform">arrow_forward</span>
                  </a>
                </div>
              </div>
              <a
                href="/armory.html"
                class="mt-8 block w-full py-3 bg-storm text-on-surface font-headline font-bold text-xs uppercase tracking-widest hover:brightness-110 transition-all text-center"
              >
                View The Armory
              </a>
            </div>
          </div>
        </section>
      </main>

      <Footer />
  </div>

  <BottomNav activePage="tour" />

  <!-- Spotlight Modal -->
  <div id="spotlight" class="hidden fixed inset-0 bg-black/90 z-[100] flex items-center justify-center p-4" onclick="closeSpotlight()">
    <img id="spotlight-img" src="" alt="Mission photo" class="max-w-full max-h-full object-contain" />
    <button class="absolute top-4 right-4 text-white" onclick="closeSpotlight()">
      <span class="material-symbols-outlined text-3xl">close</span>
    </button>
  </div>

  <script>
    function openSpotlight(src: string) {
      const el = document.getElementById('spotlight') as HTMLElement;
      const img = document.getElementById('spotlight-img') as HTMLImageElement;
      img.src = src;
      el.classList.remove('hidden');
      el.classList.add('flex');
    }
    function closeSpotlight() {
      const el = document.getElementById('spotlight') as HTMLElement;
      el.classList.add('hidden');
      el.classList.remove('flex');
    }
    (window as any).openSpotlight = openSpotlight;
    (window as any).closeSpotlight = closeSpotlight;
  </script>
</Layout>
