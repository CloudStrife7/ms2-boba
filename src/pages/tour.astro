---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MissionCard from '../components/MissionCard.astro';
import MilestoneTracker from '../components/MilestoneTracker.astro';
import NextDeployment from '../components/NextDeployment.astro';
import siteData from '../data/site.json';

const { troopCount, nextDeployment, missions } = siteData;
const base = import.meta.env.BASE_URL;
---

<Layout title="Tales of the Hunt" description="Complete mission log — every troop event, every deployment.">
  <Header activePage="tour" />

  <main class="max-w-5xl mx-auto px-4 py-10 space-y-12">

    <!-- Page heading + count -->
    <section class="hud-card-glow p-6 text-center">
      <p class="section-label mb-2">Active Contracts</p>
      <h1 class="font-display font-black text-5xl sm:text-7xl tracking-[0.1em] uppercase text-on-surface">
        Tales of the Hunt
      </h1>
      <p class="mt-3 font-display font-black text-4xl" style="color: #F59E01">
        {troopCount} MISSIONS COMPLETED
      </p>
    </section>

    <!-- Milestone tracker -->
    <MilestoneTracker troopCount={troopCount} />

    <!-- Timeline -->
    <section>
      <p class="section-label mb-6">Mission Log</p>
      <div class="relative">
        <!-- Vertical spine -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-outline-variant" />

        <div class="space-y-12">
          <!-- Next deployment at top of timeline -->
          <NextDeployment deployment={nextDeployment ?? null} />

          <!-- Mission cards — alternating sides on desktop -->
          {missions.map((mission, i) => (
            <MissionCard
              number={mission.number}
              eventName={mission.eventName}
              location={mission.location}
              date={mission.date}
              photo={mission.photo}
              align={i % 2 === 0 ? 'left' : 'right'}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Archive links -->
    <section class="hud-card p-5">
      <p class="section-label mb-3">Resources</p>
      <div class="flex flex-wrap gap-3">
        <a
          href={`https://thebhg.net/forum/index.php?/topic/8520-bobarearmored-bh-7024/`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost"
        >
          BHG Forum Thread
        </a>
        <a href="#" class="btn-ghost">2025 Campaign</a>
        <a href="#" class="btn-ghost">Request Clearance</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
