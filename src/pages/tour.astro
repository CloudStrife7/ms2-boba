---
import Layout from '../layouts/Layout.astro';
import SideNav from '../components/SideNav.astro';
import TopBar from '../components/TopBar.astro';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';
import siteData from '../data/site.json';

const { troopCount, nextDeployment, missions } = siteData;

function photoUrl(p: string) {
  return p.startsWith('http') ? p : `/${p}`;
}
---

<Layout title="Tour of Duty | MS2 Boba">
  <body class="flex min-h-screen bg-[#131411] text-[#e4e2de] font-body">

    <SideNav activePage="tour" />

    <div class="flex-1 flex flex-col md:ml-64">
      <TopBar activePage="tour" />

      <!-- Main Content Canvas -->
      <main class="flex-1 w-full max-w-5xl mx-auto px-6 py-12 md:py-20">

        <!-- Header Section -->
        <section class="mb-20">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
              <span class="font-label text-xs tracking-[0.3em] text-[#4C6043] uppercase mb-4 block">Deployment Records</span>
              <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter uppercase leading-none">
                Tour <span class="text-[#8e9288]">of</span> Duty
              </h1>
            </div>
            <div class="bg-[#131411] p-4 rounded-sm border-l-2 border-[#F59E01]">
              <div class="font-label text-[10px] text-[#8e9288] uppercase tracking-widest mb-1">Status Report</div>
              <div class="font-headline font-bold text-xl text-[#e4e2de]">{troopCount} MISSIONS LOGGED</div>
            </div>
          </div>
        </section>

        <!-- Timeline Section -->
        <section class="relative">
          <!-- Vertical Line -->
          <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-[1px] bg-[#434840] transform md:-translate-x-1/2"></div>

          <div class="space-y-24 relative">

            <!-- Next Deployment -->
            {nextDeployment && (
              <div class="relative flex flex-col md:flex-row items-start md:items-center">
                <div class="md:w-1/2 md:pr-12 md:text-right mb-4 md:mb-0">
                  <div class="font-label text-xs text-[#6D0827] tracking-widest font-bold mb-1">NEXT DEPLOYMENT</div>
                  <h3 class="font-headline text-2xl font-bold uppercase leading-tight">{nextDeployment.name}</h3>
                  <p class="font-body text-[#8e9288] text-sm mt-1">{nextDeployment.location}</p>
                </div>
                <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-[#6D0827] border-4 border-[#131411] transform -translate-x-1/2 z-[1]"></div>
                <div class="md:w-1/2 md:pl-12 pl-12">
                  <div class="font-label text-sm text-[#e4e2de] tracking-tighter uppercase">{nextDeployment.date} · {nextDeployment.time}</div>
                  <div class="mt-2 inline-flex items-center gap-2 bg-[#6D0827]/10 text-[#6D0827] px-3 py-1 rounded-sm border border-[#6D0827]/30">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#6D0827] animate-pulse"></span>
                    <span class="font-label text-[10px] uppercase font-bold tracking-widest">Awaiting Deployment</span>
                  </div>
                </div>
              </div>
            )}

            <!-- Mission entries — alternating sides -->
            {missions.map((mission, i) => {
              const isLeft = i % 2 === 0;
              return (
                <div class="relative flex flex-col md:flex-row items-start md:items-center transition-all duration-500">
                  {isLeft ? (
                    <>
                      {/* Right-side content (left on desktop) */}
                      <div class="md:w-1/2 md:pr-12 md:text-right order-2 md:order-1 pl-12 md:pl-0">
                        <div class="font-label text-sm text-[#8e9288] tracking-tighter uppercase">{mission.date}</div>
                        <div class="mt-2 inline-flex items-center gap-2 bg-[#444840]/30 px-3 py-1 rounded-sm border border-[#434840]/30">
                          <span class="material-symbols-outlined text-[12px] text-[#4C6043]">check_circle</span>
                          <span class="font-label text-[10px] uppercase font-bold tracking-widest">Mission Complete</span>
                        </div>
                        <div class="mt-4 flex flex-wrap gap-2 md:justify-end">
                          {mission.photos.map((p: string) => (
                            <img src={photoUrl(p)} alt={mission.eventName} class="w-40 h-32 object-cover rounded-sm border border-[#434840]/30" loading="lazy" />
                          ))}
                        </div>
                      </div>
                      <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-[#434840] border-2 border-[#131411] transform -translate-x-1/2 z-[1]"></div>
                      <div class="md:w-1/2 md:pl-12 mb-4 md:mb-0 order-1 md:order-2 pl-12 md:pl-12">
                        <div class="font-label text-xs text-[#8e9288] tracking-widest font-bold mb-1">DEBRIEF COMPLETE</div>
                        <h3 class="font-headline text-2xl font-bold uppercase leading-tight">{mission.eventName}</h3>
                        <p class="font-body text-[#8e9288] text-sm mt-1">{mission.location}</p>
                      </div>
                    </>
                  ) : (
                    <>
                      <div class="md:w-1/2 md:pr-12 md:text-right mb-4 md:mb-0">
                        <div class="font-label text-xs text-[#8e9288] tracking-widest font-bold mb-1">DEBRIEF COMPLETE</div>
                        <h3 class="font-headline text-2xl font-bold uppercase leading-tight">{mission.eventName}</h3>
                        <p class="font-body text-[#8e9288] text-sm mt-1">{mission.location}</p>
                      </div>
                      <div class="absolute left-4 md:left-1/2 w-3 h-3 rounded-full bg-[#434840] border-2 border-[#131411] transform -translate-x-1/2 z-[1]"></div>
                      <div class="md:w-1/2 md:pl-12 pl-12">
                        <div class="font-label text-sm text-[#8e9288] tracking-tighter uppercase">{mission.date}</div>
                        <div class="mt-2 inline-flex items-center gap-2 bg-[#444840]/30 px-3 py-1 rounded-sm border border-[#434840]/30">
                          <span class="material-symbols-outlined text-[12px] text-[#4C6043]">check_circle</span>
                          <span class="font-label text-[10px] uppercase font-bold tracking-widest">Mission Complete</span>
                        </div>
                        <div class="mt-4 flex flex-wrap gap-2">
                          {mission.photos.map((p: string) => (
                            <img src={photoUrl(p)} alt={mission.eventName} class="w-40 h-32 object-cover rounded-sm border border-[#434840]/30" loading="lazy" />
                          ))}
                        </div>
                      </div>
                    </>
                  )}
                </div>
              );
            })}

            <!-- Visual Break: Data Grid -->
            <div class="relative pt-12">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-1 bg-[#131411] border border-[#434840]/20 overflow-hidden rounded-sm">
                <div class="p-8 bg-[#1b1c19]">
                  <div class="font-label text-[10px] text-[#4C6043] tracking-widest uppercase mb-4">Tactical Coverage</div>
                  <div class="aspect-square bg-[#131411] flex items-center justify-center relative overflow-hidden group">
                    <img class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-110 transition-transform duration-700" src="/images/hero-bg.jpg" alt="Tactical coverage" />
                    <span class="material-symbols-outlined text-4xl text-[#4C6043]/50 relative z-10">location_searching</span>
                  </div>
                  <p class="font-body text-xs text-[#8e9288] mt-4">{troopCount} missions completed across Wisconsin. {nextDeployment ? `Next deployment: ${nextDeployment.name}, ${nextDeployment.date}.` : ''}</p>
                </div>
                <div class="p-8 bg-[#1b1c19]">
                  <div class="font-label text-[10px] text-[#F59E01] tracking-widest uppercase mb-4">Critical Intel</div>
                  <div class="font-headline font-bold text-3xl text-[#e4e2de] mb-2 tracking-tighter italic">"ALWAYS FIRST"</div>
                  <p class="font-body text-xs text-[#8e9288] leading-relaxed">Operatives must confirm attendance 72 hours prior to deployment for logistical synchronization.</p>
                </div>
                <div class="p-8 bg-[#1b1c19] flex flex-col justify-between">
                  <div>
                    <div class="font-label text-[10px] text-[#6D0827] tracking-widest uppercase mb-4">Archive Link</div>
                    <div class="space-y-3">
                      <a href="https://thebhg.net/forum/index.php?/topic/8520-bobarearmored-bh-7024/" target="_blank" rel="noopener" class="flex items-center justify-between group cursor-pointer">
                        <span class="font-body text-sm text-[#e4e2de] group-hover:text-[#4C6043] transition-colors">BHG Forum Thread</span>
                        <span class="material-symbols-outlined text-sm text-[#8e9288] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                      </a>
                      <div class="w-full h-[1px] bg-[#434840]/20"></div>
                      <div class="flex items-center justify-between group cursor-pointer">
                        <span class="font-body text-sm text-[#e4e2de] group-hover:text-[#4C6043] transition-colors">2025 Campaign</span>
                        <span class="material-symbols-outlined text-sm text-[#8e9288] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                      </div>
                    </div>
                  </div>
                  <a href="/armory.html" class="mt-8 block w-full py-3 bg-[#4C6043] text-[#e4e2de] font-headline font-bold text-xs uppercase tracking-widest hover:brightness-110 transition-all text-center">
                    View The Armory
                  </a>
                </div>
              </div>
            </div>

          </div>
        </section>
      </main>

      <Footer />
    </div>

    <!-- BottomNavBar (Mobile Only) -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#131411] py-3 px-6 flex justify-around items-center z-50 border-t border-[#1b1c19]">
      <a href="/index.html"><span class="material-symbols-outlined text-[#b7cda9]/60">terminal</span></a>
      <a href="/about.html"><span class="material-symbols-outlined text-[#b7cda9]/60">person</span></a>
      <a href="/tour.html"><span class="material-symbols-outlined text-[#F59E01]" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24">radar</span></a>
      <a href="/armory.html"><span class="material-symbols-outlined text-[#b7cda9]/60">inventory_2</span></a>
    </nav>

  </body>
</Layout>
